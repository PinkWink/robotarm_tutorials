<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="robot_arm">

  <!-- ==================== -->
  <!--   Material Colors     -->
  <!-- ==================== -->
  <material name="white">
    <color rgba="1.0 1.0 1.0 1.0"/>
  </material>
  <material name="grey">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <material name="dark_grey">
    <color rgba="0.3 0.3 0.3 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.2 0.4 0.8 1.0"/>
  </material>
  <material name="light_blue">
    <color rgba="0.4 0.6 0.9 1.0"/>
  </material>
  <material name="orange">
    <color rgba="1.0 0.5 0.0 1.0"/>
  </material>

  <!-- ==================== -->
  <!--   Link Macro          -->
  <!-- ==================== -->
  <xacro:macro name="arm_link" params="name length radius color">
    <link name="${name}">
      <visual>
        <geometry>
          <cylinder length="${length}" radius="${radius}"/>
        </geometry>
        <origin xyz="0 0 ${length/2}" rpy="0 0 0"/>
        <material name="${color}"/>
      </visual>
      <collision>
        <geometry>
          <cylinder length="${length}" radius="${radius}"/>
        </geometry>
        <origin xyz="0 0 ${length/2}" rpy="0 0 0"/>
      </collision>
      <inertial>
        <mass value="1.0"/>
        <origin xyz="0 0 ${length/2}" rpy="0 0 0"/>
        <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.005"/>
      </inertial>
    </link>
  </xacro:macro>

  <!-- ==================== -->
  <!--   Joint Sphere Macro  -->
  <!-- ==================== -->
  <xacro:macro name="joint_sphere" params="name radius color parent_link">
    <link name="${name}_sphere">
      <visual>
        <geometry>
          <sphere radius="${radius}"/>
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <material name="${color}"/>
      </visual>
      <collision>
        <geometry>
          <sphere radius="${radius}"/>
        </geometry>
        <origin xyz="0 0 0" rpy="0 0 0"/>
      </collision>
      <inertial>
        <mass value="0.2"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
      </inertial>
    </link>
  </xacro:macro>

  <!-- ==================== -->
  <!--   Base Link (fixed)   -->
  <!-- ==================== -->
  <link name="world"/>

  <link name="base_link">
    <visual>
      <geometry>
        <cylinder length="0.05" radius="0.08"/>
      </geometry>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <cylinder length="0.05" radius="0.08"/>
      </geometry>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ==================== -->
  <!--   Joint 1 (Base Yaw) -->
  <!-- ==================== -->
  <xacro:joint_sphere name="joint1" radius="0.04" color="orange" parent_link="base_link"/>
  <joint name="joint1_fixed" type="fixed">
    <parent link="base_link"/>
    <child link="joint1_sphere"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>

  <xacro:arm_link name="link1" length="0.18" radius="0.035" color="blue"/>
  <joint name="joint1" type="revolute">
    <parent link="joint1_sphere"/>
    <child link="link1"/>
    <origin xyz="0 0 0.0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${-pi}" upper="${pi}" effort="100" velocity="1.0"/>
  </joint>

  <!-- ==================== -->
  <!--   Joint 2 (Shoulder)  -->
  <!-- ==================== -->
  <xacro:joint_sphere name="joint2" radius="0.04" color="orange" parent_link="link1"/>
  <joint name="joint2_fixed" type="fixed">
    <parent link="link1"/>
    <child link="joint2_sphere"/>
    <origin xyz="0 0 0.18" rpy="0 0 0"/>
  </joint>

  <xacro:arm_link name="link2" length="0.20" radius="0.03" color="light_blue"/>
  <joint name="joint2" type="revolute">
    <parent link="joint2_sphere"/>
    <child link="link2"/>
    <origin xyz="0 0 0.0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${-pi}" upper="${pi}" effort="100" velocity="1.0"/>
  </joint>

  <!-- ==================== -->
  <!--   Joint 3 (Elbow)     -->
  <!-- ==================== -->
  <xacro:joint_sphere name="joint3" radius="0.035" color="orange" parent_link="link2"/>
  <joint name="joint3_fixed" type="fixed">
    <parent link="link2"/>
    <child link="joint3_sphere"/>
    <origin xyz="0 0 0.20" rpy="0 0 0"/>
  </joint>

  <xacro:arm_link name="link3" length="0.18" radius="0.025" color="blue"/>
  <joint name="joint3" type="revolute">
    <parent link="joint3_sphere"/>
    <child link="link3"/>
    <origin xyz="0 0 0.0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${-pi}" upper="${pi}" effort="100" velocity="1.0"/>
  </joint>

  <!-- ==================== -->
  <!--   Joint 4 (Wrist 1)   -->
  <!-- ==================== -->
  <xacro:joint_sphere name="joint4" radius="0.03" color="orange" parent_link="link3"/>
  <joint name="joint4_fixed" type="fixed">
    <parent link="link3"/>
    <child link="joint4_sphere"/>
    <origin xyz="0 0 0.18" rpy="0 0 0"/>
  </joint>

  <xacro:arm_link name="link4" length="0.10" radius="0.02" color="light_blue"/>
  <joint name="joint4" type="revolute">
    <parent link="joint4_sphere"/>
    <child link="link4"/>
    <origin xyz="0 0 0.0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${-pi}" upper="${pi}" effort="50" velocity="1.5"/>
  </joint>

  <!-- ==================== -->
  <!--   Joint 5 (Wrist 2)   -->
  <!-- ==================== -->
  <xacro:joint_sphere name="joint5" radius="0.025" color="orange" parent_link="link4"/>
  <joint name="joint5_fixed" type="fixed">
    <parent link="link4"/>
    <child link="joint5_sphere"/>
    <origin xyz="0 0 0.10" rpy="0 0 0"/>
  </joint>

  <xacro:arm_link name="link5" length="0.08" radius="0.018" color="blue"/>
  <joint name="joint5" type="revolute">
    <parent link="joint5_sphere"/>
    <child link="link5"/>
    <origin xyz="0 0 0.0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="${-pi}" upper="${pi}" effort="50" velocity="1.5"/>
  </joint>

  <!-- ==================== -->
  <!--   Joint 6 (Wrist 3)   -->
  <!-- ==================== -->
  <xacro:joint_sphere name="joint6" radius="0.022" color="orange" parent_link="link5"/>
  <joint name="joint6_fixed" type="fixed">
    <parent link="link5"/>
    <child link="joint6_sphere"/>
    <origin xyz="0 0 0.08" rpy="0 0 0"/>
  </joint>

  <xacro:arm_link name="link6" length="0.04" radius="0.018" color="light_blue"/>
  <joint name="joint6" type="revolute">
    <parent link="joint6_sphere"/>
    <child link="link6"/>
    <origin xyz="0 0 0.0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="${-pi}" upper="${pi}" effort="30" velocity="2.0"/>
  </joint>

  <!-- ========================= -->
  <!--   Gripper Base             -->
  <!-- ========================= -->
  <link name="gripper_base">
    <visual>
      <geometry>
        <box size="0.06 0.02 0.02"/>
      </geometry>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.06 0.02 0.02"/>
      </geometry>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0.01" rpy="0 0 0"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="gripper_base_joint" type="fixed">
    <parent link="link6"/>
    <child link="gripper_base"/>
    <origin xyz="0 0 0.04" rpy="0 0 0"/>
  </joint>

  <!-- ========================= -->
  <!--   Left Finger              -->
  <!-- ========================= -->
  <link name="left_finger">
    <visual>
      <geometry>
        <box size="0.01 0.01 0.06"/>
      </geometry>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.01 0.01 0.06"/>
      </geometry>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="left_finger_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="left_finger"/>
    <origin xyz="0.02 0 0.02" rpy="0 0 0"/>
    <axis xyz="-1 0 0"/>
    <limit lower="0.0" upper="0.02" effort="10" velocity="0.5"/>
  </joint>

  <!-- ========================= -->
  <!--   Right Finger             -->
  <!-- ========================= -->
  <link name="right_finger">
    <visual>
      <geometry>
        <box size="0.01 0.01 0.06"/>
      </geometry>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <material name="grey"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.01 0.01 0.06"/>
      </geometry>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="right_finger_joint" type="fixed">
    <parent link="gripper_base"/>
    <child link="right_finger"/>
    <origin xyz="-0.02 0 0.02" rpy="0 0 0"/>
  </joint>

  <!-- ========================= -->
  <!--   ros2_control Interface   -->
  <!-- ========================= -->
  <ros2_control name="robot_arm_system" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    <joint name="joint1">
      <command_interface name="position">
        <param name="min">-3.14159</param>
        <param name="max">3.14159</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="joint2">
      <command_interface name="position">
        <param name="min">-3.14159</param>
        <param name="max">3.14159</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="joint3">
      <command_interface name="position">
        <param name="min">-3.14159</param>
        <param name="max">3.14159</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="joint4">
      <command_interface name="position">
        <param name="min">-3.14159</param>
        <param name="max">3.14159</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="joint5">
      <command_interface name="position">
        <param name="min">-3.14159</param>
        <param name="max">3.14159</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="joint6">
      <command_interface name="position">
        <param name="min">-3.14159</param>
        <param name="max">3.14159</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <joint name="left_finger_joint">
      <command_interface name="position">
        <param name="min">0.0</param>
        <param name="max">0.02</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

  </ros2_control>

  <!-- ========================= -->
  <!--   Gazebo ros2_control      -->
  <!-- ========================= -->
  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find robot_arm_moveit_config)/config/ros2_controllers.yaml</parameters>
    </plugin>
  </gazebo>

  <!-- ========================= -->
  <!--   Gazebo Visual Colors     -->
  <!-- ========================= -->
  <gazebo reference="base_link">
    <material>
      <ambient>0.3 0.3 0.3 1.0</ambient>
      <diffuse>0.3 0.3 0.3 1.0</diffuse>
    </material>
  </gazebo>
  <gazebo reference="joint1_sphere">
    <material>
      <ambient>1.0 0.5 0.0 1.0</ambient>
      <diffuse>1.0 0.5 0.0 1.0</diffuse>
    </material>
  </gazebo>
  <gazebo reference="link1">
    <material>
      <ambient>0.2 0.4 0.8 1.0</ambient>
      <diffuse>0.2 0.4 0.8 1.0</diffuse>
    </material>
  </gazebo>
  <gazebo reference="joint2_sphere">
    <material>
      <ambient>1.0 0.5 0.0 1.0</ambient>
      <diffuse>1.0 0.5 0.0 1.0</diffuse>
    </material>
  </gazebo>
  <gazebo reference="link2">
    <material>
      <ambient>0.4 0.6 0.9 1.0</ambient>
      <diffuse>0.4 0.6 0.9 1.0</diffuse>
    </material>
  </gazebo>
  <gazebo reference="joint3_sphere">
    <material>
      <ambient>1.0 0.5 0.0 1.0</ambient>
      <diffuse>1.0 0.5 0.0 1.0</diffuse>
    </material>
  </gazebo>
  <gazebo reference="link3">
    <material>
      <ambient>0.2 0.4 0.8 1.0</ambient>
      <diffuse>0.2 0.4 0.8 1.0</diffuse>
    </material>
  </gazebo>
  <gazebo reference="joint4_sphere">
    <material>
      <ambient>1.0 0.5 0.0 1.0</ambient>
      <diffuse>1.0 0.5 0.0 1.0</diffuse>
    </material>
  </gazebo>
  <gazebo reference="link4">
    <material>
      <ambient>0.4 0.6 0.9 1.0</ambient>
      <diffuse>0.4 0.6 0.9 1.0</diffuse>
    </material>
  </gazebo>
  <gazebo reference="joint5_sphere">
    <material>
      <ambient>1.0 0.5 0.0 1.0</ambient>
      <diffuse>1.0 0.5 0.0 1.0</diffuse>
    </material>
  </gazebo>
  <gazebo reference="link5">
    <material>
      <ambient>0.2 0.4 0.8 1.0</ambient>
      <diffuse>0.2 0.4 0.8 1.0</diffuse>
    </material>
  </gazebo>
  <gazebo reference="joint6_sphere">
    <material>
      <ambient>1.0 0.5 0.0 1.0</ambient>
      <diffuse>1.0 0.5 0.0 1.0</diffuse>
    </material>
  </gazebo>
  <gazebo reference="link6">
    <material>
      <ambient>0.4 0.6 0.9 1.0</ambient>
      <diffuse>0.4 0.6 0.9 1.0</diffuse>
    </material>
  </gazebo>
  <gazebo reference="gripper_base">
    <material>
      <ambient>0.3 0.3 0.3 1.0</ambient>
      <diffuse>0.3 0.3 0.3 1.0</diffuse>
    </material>
  </gazebo>
  <gazebo reference="left_finger">
    <material>
      <ambient>0.5 0.5 0.5 1.0</ambient>
      <diffuse>0.5 0.5 0.5 1.0</diffuse>
    </material>
  </gazebo>
  <gazebo reference="right_finger">
    <material>
      <ambient>0.5 0.5 0.5 1.0</ambient>
      <diffuse>0.5 0.5 0.5 1.0</diffuse>
    </material>
  </gazebo>

</robot>
